# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=bronze
MINIO_SECURE=false

# Kaggle (bronze importer)
KAGGLE_USERNAME=
KAGGLE_KEY=
BRONZE_DATASET_SLUG=skihikingkevin/csgo-matchmaking-damage
BRONZE_DATASET_PREFIX=csgo-matchmaking-damage
BRONZE_RUN_ID=

# Silver transformer
SILVER_BUCKET=silver
SILVER_DATASET_PREFIX=csgo-matchmaking-damage
BRONZE_SOURCE_RUN_ID=
SILVER_RUN_ID=

# Gold transformer
SILVER_SOURCE_RUN_ID=
GOLD_BUCKET=gold
GOLD_DATASET_PREFIX=
GOLD_RUN_ID=
GOLD_SOURCE_RUN_ID=

# Document builder
DOCUMENT_BUCKET=
DOCUMENT_DATASET_PREFIX=
DOCUMENT_RUN_ID=
DOCUMENT_PART_SIZE_ROWS=100000
DOCUMENT_MAX_ROWS=
DOCUMENT_SOURCE_RUN_ID=

# Embedding ingestor
EMBEDDING_REPORT_BUCKET=
EMBEDDING_DATASET_PREFIX=
EMBEDDING_RUN_ID=
EMBEDDING_BATCH_SIZE=256
EMBEDDING_NUM_WORKERS=4
EMBEDDING_PARALLEL_BATCHES=4
EMBEDDING_MAX_DOCUMENTS=
EMBEDDING_RESUME=false

# TimescaleDB / pgvectorscale
PG_HOST=localhost
PG_PORT=54330
PG_USER=raguser
PG_PASSWORD=ragpassword
PG_DATABASE=ragdb
PG_TABLE_NAME=rag_embeddings
PG_EMBED_DIM=768

# Ollama (local fallback)
OLLAMA_BASE_URL=http://localhost:11434
COMPOSE_OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_EMBED_BATCH_SIZE=32
OLLAMA_NUM_PARALLEL=4

# API keys (optional — falls back to Ollama when absent)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# Provider defaults
DEFAULT_LLM=ollama/qwen2.5
DEFAULT_EMBED_MODEL=ollama/nomic-embed-text
DEFAULT_EMBEDDING_RUN_ID=

# API server
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*

# Frontend chat
RAG_API_URL=http://localhost:8000
EMBEDDING_RUN_ID=
CHAT_PROVIDER=ollama
CHAT_PROVIDER_BASE_URL=http://127.0.0.1:8080/v1
CHAT_PROVIDER_API_KEY=local
CHAT_MODEL=
CHAT_DEFAULT_MODEL=
CHAT_MODEL_LABEL=
CHAT_MODEL_SUPPORTS_REASONING=false
CHAT_MODEL_SUPPORTS_TOOLS=true

# Logging
LOG_LEVEL=INFO
LOG_JSON=

# OpenTelemetry (enable with: docker compose --profile observability up -d)
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4318

# MLflow (enable with: docker compose --profile mlflow up -d)
# From the host / local Python: use localhost. From other Compose services: http://mlflow:5000
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=csgo_round_next_winner

# ML Training (train-logreg / train-histgbt / train-baseline)
TRAIN_RUN_ID=
TRAIN_TEST_SIZE=0.2
TRAIN_RANDOM_STATE=42
TRAIN_MODEL_NAME=
