# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=bronze
MINIO_SECURE=false

# Kaggle (bronze importer)
KAGGLE_USERNAME=
KAGGLE_KEY=
BRONZE_DATASET_SLUG=skihikingkevin/csgo-matchmaking-damage
BRONZE_DATASET_PREFIX=csgo-matchmaking-damage
BRONZE_RUN_ID=

# Silver transformer
SILVER_BUCKET=silver
SILVER_DATASET_PREFIX=csgo-matchmaking-damage
BRONZE_SOURCE_RUN_ID=
SILVER_RUN_ID=

# Gold transformer
SILVER_SOURCE_RUN_ID=
GOLD_BUCKET=gold
GOLD_DATASET_PREFIX=
GOLD_RUN_ID=
GOLD_SOURCE_RUN_ID=

# Document builder
DOCUMENT_BUCKET=
DOCUMENT_DATASET_PREFIX=
DOCUMENT_RUN_ID=
DOCUMENT_PART_SIZE_ROWS=100000

# TimescaleDB / pgvectorscale
PG_HOST=localhost
PG_PORT=54330
PG_USER=raguser
PG_PASSWORD=ragpassword
PG_DATABASE=ragdb
PG_TABLE_NAME=rag_embeddings
PG_EMBED_DIM=768

# Ollama (local fallback)
OLLAMA_BASE_URL=http://localhost:11434

# API keys (optional — falls back to Ollama when absent)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# Provider defaults
DEFAULT_LLM=ollama/qwen2.5
DEFAULT_EMBED_MODEL=ollama/nomic-embed

# API server
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
LOG_JSON=

# OpenTelemetry (enable with: docker compose --profile observability up -d)
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4318
